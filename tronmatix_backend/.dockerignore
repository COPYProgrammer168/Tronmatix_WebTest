# ── Node modules (heavy, rebuilt in Docker) ───────────────────────────────────
node_modules/
tronmatix_frontend/node_modules/

# ── Build output (rebuilt in Docker) ─────────────────────────────────────────
tronmatix_frontend/dist/
tronmatix_frontend/.vite/
public/build/
public/spa/

# ── Laravel cache (regenerated in Docker) ────────────────────────────────────
vendor/
bootstrap/cache/*.php
storage/logs/*.log

# ── Git / IDE ─────────────────────────────────────────────────────────────────
.git/
.github/
.vscode/
.idea/

# ── Secrets — NEVER include .env in Docker image ─────────────────────────────
.env
.env.backup
.env.production
# Keep .env.example — used as fallback template in Dockerfile
!.env.example

# IMPORTANT: tronmatix_frontend/ SOURCE must NOT be ignored
# Docker needs it to build the React app
# Do NOT add tronmatix_frontend/ here
